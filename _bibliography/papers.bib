@article{haozhe2026cadloop,
  abbr      = {CVPR-W},
  author    = {Haozhe Zhang and Kaichen Liu and Miaomiao Chen and Lei Li and Shaojie Yang and Cheng Peng and Hanjie Chen},
  booktitle = {CVPR 2026 Workshop on Exploring the Next Generation of Data (NeXD)},
  title     = {CADLoop: An Equivariant-Aware Skill-Grounded Loop for CAD Data Curation},
  year      = {2026},
  publisher = {},
  volume    = {},
  number    = {},
  pages     = {},
  doi       = {},
  url       = {},
  html      = {},
  selected  = {false},
  abstract  = {High-quality programmatic CAD datasets are critical for training multimodal models capable of generating executable CAD code. However, automatically verified CAD programs frequently contain small geometric inconsistencies that invalidate otherwise correct structures, making large-scale dataset construction difficult. We observe that a large fraction of failures fall into a near-miss regime (IoU approx 0.8), where the generated topology is correct but continuous parameters are misaligned. We introduce CADLoop, a neuro-symbolic data curation pipeline that automatically verifies and repairs such near-miss programs. CADLoop decouples structural reasoning from deterministic geometric execution: a Vision-Language Model (VLM) infers the high-level design intent, while a symbolic geometric module analytically resolves continuous constraints and directly modifies the CAD program's abstract syntax tree (AST). Evaluated on 1,619 CAD models from the Fusion360 Gallery, CADLoop identifies 226 near-miss cases and successfully repairs all of them, improving the pass rate from approximately 91 percent with Re-Act loops to 100 percent while substantially reducing geometric error. The resulting dataset contains 1,646 verified program-geometry pairs with IoU >= 0.99. Our results demonstrate that deterministic geometric verification can transform imperfect generations into high-quality training assets, enabling scalable construction of datasets for future multimodal CAD generation models.},
}


@article{haozhe2026benchcad,
  abbr      = {arXiv},
  preview   = {benchcad.webp},
  author    = {Haozhe Zhang and Kaichen Liu and Miaomiao Chen and Lei Li and Shaojie Yang and Cheng Peng and Hanjie Chen},
  booktitle = {arXiv preprint arXiv:2605.10865},
  title     = {BenchCAD: A Comprehensive, Industry-Standard Benchmark for Programmatic CAD},
  year      = {2026},
  publisher = {},
  volume    = {},
  number    = {},
  pages     = {},
  doi       = {},
  url       = {https://arxiv.org/abs/2605.10865},
  html      = {https://arxiv.org/abs/2605.10865},
  selected  = {true},
  project   = {/projects/1_project/},
  abstract  = {We present BenchCAD, a comprehensive industry-standard benchmark for evaluating programmatic CAD code generation. The benchmark includes over 17,000 execution-verified CadQuery programs spanning 106 industrial part families (e.g., gears, springs, drills) and assesses models across visual question answering, code analysis, image-to-code conversion, and code editing. Our results show that current models often recover coarse outer geometry but fail to produce faithful parametric CAD programs, with common failure modes including missing structural details and oversimplified operations; generalization to unseen part families remains limited even after fine-tuning.},
}


@article{yu2026ijhmt,
  abbr      = {IJHMT},
  author    = {Xiaotong Yu and Kai Chen and Weiyan Chen and Ziqiao Chen and Haozhe Zhang and Baoxing Xu and Rong Chen and Yuan Gao},
  booktitle = {International Journal of Heat and Mass Transfer},
  title     = {Enhancing device-to-substrate thermal transport by limiting the flexural rigidity of heat-spreading interlayers},
  year      = {2026},
  volume    = {256},
  pages     = {},
  url       = {https://www.sciencedirect.com/journal/international-journal-of-heat-and-mass-transfer},
  html      = {https://www.sciencedirect.com/journal/international-journal-of-heat-and-mass-transfer},
  selected  = {false},
  abstract  = {Heat dissipation across the device-to-substrate interface is a critical bottleneck for high-power-density electronics. This work shows that limiting the flexural rigidity of heat-spreading interlayers enhances conformal contact and significantly improves device-to-substrate thermal transport, providing a design rule for thermal interface architectures in advanced electronic packaging.},
}


@article{chen2025nl,
  abbr      = {Nano Lett.},
  author    = {Ziqiao Chen and Rui He and Xiaotong Yu and Haozhe Zhang and Rong Chen and Baoxing Xu and Yuan Gao},
  booktitle = {Nano Letters},
  title     = {Degradation of Hydrogen Bonds Enormously Enhances Convective Heat Transfer in Nanofluidics},
  year      = {2025},
  volume    = {25},
  number    = {16},
  pages     = {6508--6515},
  doi       = {10.1021/acs.nanolett.5c00241},
  url       = {https://pubs.acs.org/doi/10.1021/acs.nanolett.5c00241},
  html      = {https://pubs.acs.org/doi/10.1021/acs.nanolett.5c00241},
  selected  = {false},
  abstract  = {Convective heat transfer in nanochannels can be enhanced by approximately 50% due to the deterioration of hydrogen bonds under internal stress. Degraded hydrogen bonds weaken the intrinsic constraints from local confinement, significantly promoting the mobility of confined liquid molecules and facilitating phonon transmission for rapid heat transfer. A thermal–mechanics scaling law correlates internal stress with convective heat transfer through the Nusselt number and the liquid–solid interaction energy, providing theoretical insights for designing nanofluidics-based cooling strategies for high-power-density electronics.},
}


@article{haozhe2025buckling,
  abbr      = {Mech. Mater.},
  author    = {Haozhe Zhang and Yuan Gao and Baoxing Xu},
  booktitle = {Mechanics of Materials},
  title     = {A buckling mechanics model for pattern transformation of lattice superstructures assembled by soft-hard materials integrated units},
  year      = {2025},
  volume    = {202},
  pages     = {105253},
  url       = {https://www.sciencedirect.com/journal/mechanics-of-materials},
  html      = {https://www.sciencedirect.com/journal/mechanics-of-materials},
  selected  = {false},
  project   = {/projects/5_project/},
  abstract  = {We develop a buckling mechanics model for the pattern transformation of lattice superstructures assembled by soft-hard material integrated units. The model captures how the soft-hard contrast governs the critical buckling load and post-buckling reorganization of unit rotations, predicting the emergence of distinct ordered patterns. Theory and finite-element analysis agree on how unit geometry and material contrast steer pattern selection, offering a route to program reconfigurable lattice metamaterials.},
}


@article{kim2024scia,
  abbr      = {Sci. Adv.},
  author    = {Kyungbin Kim and Jung-Hoon Hong and Kyungtaek Bae and Kunhee Lee and Dong Jun Lee and Junseong Park and Haozhe Zhang and Mingyu Sang and Ji-Eun Ju and others},
  booktitle = {Science Advances},
  title     = {Extremely durable electrical impedance tomography--based soft and ultrathin wearable e-skin for three-dimensional tactile interfaces},
  year      = {2024},
  volume    = {10},
  number    = {38},
  pages     = {eadr1099},
  doi       = {10.1126/sciadv.adr1099},
  url       = {https://www.science.org/doi/10.1126/sciadv.adr1099},
  html      = {https://www.science.org/doi/10.1126/sciadv.adr1099},
  selected  = {false},
  project   = {/projects/4_project/},
  abstract  = {We introduce a thin and soft electrical impedance tomography (EIT) based e-skin for tactile interfaces. The conductive and stretchable sensing domain uses a micropatterned multi-walled carbon nanotube/elastomer composite. The EIT-based tactile interface discerns external pressures to a sub-millimeter degree and vertical deformations of a few hundred micrometers, sustaining stable functions under damage or environmental changes. We demonstrate real-time human–machine interface applications including handwriting recognition and drone control.},
}


@article{hong2024ami,
  abbr      = {ACS AMI},
  author    = {Seungse Hong and Haozhe Zhang and Jiwoo Lee and Taemin Yu and Sungjun Cho and Taeyeong Park and Jacob Walsh and Yuhang Ji and Jin Jea Kim and Hyowon Lee and others},
  booktitle = {ACS Applied Materials \& Interfaces},
  title     = {Spongy Ag Foam for Soft and Stretchable Strain Gauges},
  year      = {2024},
  volume    = {16},
  number    = {20},
  pages     = {26613--26623},
  doi       = {10.1021/acsami.4c04719},
  url       = {https://pubs.acs.org/doi/10.1021/acsami.4c04719},
  html      = {https://pubs.acs.org/doi/10.1021/acsami.4c04719},
  selected  = {false},
  abstract  = {We present strain gauges built from spongy Ag foam via a steam-etching process, a simpler and more eco-friendly alternative to conventional fabrication. The gauges achieve a gauge factor exceeding 8 x 10^3 at strains over 100% while preserving stretchability and durability. Systematic studies reveal the structure-property-performance relationships, and we demonstrate the gauges in human-motion monitoring and human-robot interaction.},
}


@article{gao2023am,
  abbr      = {Adv. Mater.},
  author    = {Yuan Gao and Mingzhe Li and Chuanyong Zhan and Haozhe Zhang and Mengtian Yin and Weiyi Lu and Baoxing Xu},
  booktitle = {Advanced Materials},
  title     = {A Nanoconfined Water--Ion Coordination Network for Flexible Energy-Dissipation Devices},
  year      = {2023},
  volume    = {35},
  number    = {42},
  pages     = {2303759},
  doi       = {10.1002/adma.202303759},
  url       = {https://advanced.onlinelibrary.wiley.com/doi/10.1002/adma.202303759},
  html      = {https://advanced.onlinelibrary.wiley.com/doi/10.1002/adma.202303759},
  selected  = {false},
  abstract  = {We report a water-ion coordination network of water-water, water-ion, and ion-ion interactions in LiCl solution confined in a hydrophobic nanopore. Confinement enhances the interaction intensity nearly fourfold relative to bulk, strongly couples with the interaction correlation time, and drives formation of local ion clusters and bound water. Unlike localized effects in bulk liquids, the nanoconfined network globally suppresses rotational and translational dynamics. Simulations and experiments demonstrate that this can be leveraged in a reusable flexible liquid-nanopore energy-dissipation system that attenuates pressure during impact unloading.},
}


@article{haozhe2022am,
  abbr      = {Adv. Mater.},
  preview   = {Janus.png},
  author    = {Haozhe Zhang and Weizhu Yang and Qingchang Liu and Yuan Gao and Zhufeng Yue and Baoxing Xu},
  booktitle = {Advanced Materials},
  title     = {Mechanical Janus Structures by Soft‐Hard Material Integration},
  year      = {2022},
  publisher = {},
  volume    = {},
  number    = {},
  pages     = {},
  doi       = {},
  url       = {https://onlinelibrary.wiley.com/doi/abs/10.1002/adma.202208339},
  html      = {https://onlinelibrary.wiley.com/doi/abs/10.1002/adma.202208339},
  selected  = {false},
  project   = {/projects/5_project/},
  abstract  = {Engineering Janus structures that possess anisotropic features in functions have attracted growing attention for a wide range of applications in sensors, catalysis, and biomedicine, and are yet usually designed at the nanoscale with distinct physical or chemical functionalities in their opposite sides. Inspired by the seamless integration of soft and hard materials in biological structures, here we present a mechanical Janus structure composed of soft and hard materials with a dramatic difference of mechanical properties at additively manufacturable macroscale. We establish, in the combination of extensive experimental, theoretical, and computational studies, the design principle of soft-hard materials integrated mechanical Janus structures and address their unique rotation mechanism. We further show the systematic studies of assembling the Janus structure units into superstructures with well-ordered organizations by programing their local rotations, providing a direct route of designing superstructures by leveraging mechanical Janus structures with unique soft-hard material integration. Applications are conducted to demonstrate the features and functionalities of assembled superstructures with local ordered organizations in regulating and filtering acoustic wave propagations, thereby providing exemplification applications of mechanical Janus design in functional structures and devices.},
}


@article{yuan2022acsnano,
  abbr      = {ACS Nano},
  preview   = {water.png},
  author    = {Yuan Gao and Mengtian Yin and Haozhe Zhang and Baoxing Xu},
  booktitle = {ACS nano},
  title     = {Electrically Suppressed Outflow of Confined Liquid in Hydrophobic Nanopores},
  year      = {2022},
  publisher = {},
  volume    = {},
  number    = {},
  pages     = {},
  doi       = {},
  url       = {https://pubs.acs.org/doi/full/10.1021/acsnano.2c02240},
  html      = {https://pubs.acs.org/doi/full/10.1021/acsnano.2c02240},
  selected  = {false},
  project   = {/projects/7_project/},
  abstract  = {Confining liquid in a hydrophobic nanoenvironment has enabled a broad spectrum of applications in biomedical sensors, mechanical actuators, and energy storage and converters, where the outflow of confined liquid is spontaneous and fast due to the intrinsic hydrophobic nature of nanopores with extremely low interfacial friction, challenging design capacity and control tolerance of structures and devices. Here, we present a facile approach of suppressing the outflow of water confined in hydrophobic nanopores with an electric field. Extensive molecular dynamics simulations show that the presence of an electric field could significantly strengthen hydrogen bonds and retard degradations of the associated networks during the outflow. The outflow deformation and strength are extracted to quantitatively characterize the electrical suppression to outflow and agree well with simulations. This study proposes a practical means of impeding the fast liquid outflow in hydrophobic nanopores, potentially useful for devising nanofluidics-based functional structures and devices with controllable performance.},
}


@article{yuan2022matter,
  abbr      = {Matter},
  preview   = {water.png},
  author    = {Yuan Gao and Mingzhe Li and Haozhe Zhang and Yue Zhang and Weiyi Lu and Baoxing Xu},
  booktitle = {Matter},
  title     = {Anomalous solid-like necking of confined water outflow in hydrophobic nanopores},
  year      = {2022},
  publisher = {},
  volume    = {5},
  number    = {1},
  pages     = {266--280},
  doi       = {},
  url       = {https://www.sciencedirect.com/science/article/abs/pii/S2590238521006160},
  html      = {https://www.sciencedirect.com/science/article/abs/pii/S2590238521006160},
  selected  = {false},
  project   = {/projects/7_project/},
  abstract  = {Outflow of water confined in hydrophobic nanopores exhibits an unexpected solid-like necking behavior reminiscent of metals under uniaxial tension. Molecular dynamics simulations and theoretical analysis reveal that hydrogen-bond networks and confinement-induced stress give rise to a tensile-like deformation response during outflow, providing fundamental insights for nanofluidic devices exploiting confined liquid mechanics.},
}

@article{haozhe2022apl,
  abbr      = {APL},
  preview   = {robot.png},
  author    = {Haozhe Zhang and Baoxing Xu},
  booktitle = {applied physics letter },
  title     = {Soft-hard material integration enabled programmable robotic locomotion},
  year      = {2022},
  publisher = {},
  volume    = {},
  number    = {},
  pages     = {},
  doi       = {},
  url       = {https://aip.scitation.org/doi/abs/10.1063/5.0127845},
  html      = {https://aip.scitation.org/doi/abs/10.1063/5.0127845},
  selected  = {false},
  project   = {/projects/5_project/},
  abstract  = {Inspired by the opening and closing mechanism of clams, herein, we present a two-dimensional robot by integrating soft-hard materials with structural design and demonstrate a variety of in-plane locomotion modes from a straight line to a circle. A theoretical model is developed to quantitatively predict the locomotion direction and step distance, and the results show remarkable agreement with finite element analysis. Systematic applications are further conducted to demonstrate programmable locomotion behavior by regulating the mechanical stimuli and arranging the order of soft-hard material integrated units. This work provides a rational route for designing diverse strategies of robotic locomotion with soft-hard material integration.}
}


@article{mingyu2022am,
  abbr      = {Adv. Mater.},
  preview   = {thermal_sensor.png},
  author    = {Mingyu Sang and Kyowon Kang and Yue Zhang and Haozhe Zhang and Kiho Kim and Myeongki Cho and Jongwoon Shin and Jung‐Hoon Hong and Taemin Kim and Shin Kyu Lee and Woon‐Hong Yeo and Jung Woo Lee and Taeyoon Lee and Baoxing Xu and Ki Jun Yu},
  booktitle = {Advanced Materials},
  title     = {Ultrahigh Sensitive Au‐Doped Silicon Nanomembrane Based Wearable Sensor Arrays for Continuous Skin Temperature Monitoring with High Precision},
  year      = {2022},
  publisher = {},
  volume    = {},
  number    = {},
  pages     = {},
  doi       = {},
  url       = {https://onlinelibrary.wiley.com/doi/abs/10.1002/adma.202105865},
  html      = {https://onlinelibrary.wiley.com/doi/abs/10.1002/adma.202105865},
  selected  = {false},
  project   = {/projects/4_project/},
  abstract  = {Monitoring the body temperature with high accuracy provides a fast, facile, yet powerful route about the human body in a wide range of health information standards. Here, the first ever ultrasensitive and stretchable gold-doped silicon nanomembrane (Au-doped SiNM) epidermal temperature sensor array is introduced. The ultrasensitivity is achieved by shifting freeze-out region to intrinsic region in carrier density and modulation of fermi energy level of p-type SiNM through the development of a novel gold-doping strategy. The Au-doped SiNM is readily transferred onto an ultrathin polymer layer with a well-designed serpentine mesh structure, capable of being utilized as an epidermal temperature sensor array. Measurements in vivo and in vitro show temperature coefficient of resistance as high as −37270.72 ppm °C−1, 22 times higher than existing metal-based temperature sensors with similar structures, and one of the highest thermal sensitivity among the inorganic material based temperature sensors. Applications in the continuous monitoring of body temperature and respiration rate during exercising are demonstrated with a successful capture of information. This work lays a foundation for monitoring body temperature, potentially useful for precision diagnosis (e.g., continuous monitoring body temperature in coronavirus disease 2019 cases) and management of disease relevance to body temperature in healthcare.},
}


@article{shifeng2021cm,
  abbr      = {Chem. Mater.},
  preview   = {elastomer.png},
  author    = {Shifeng Nian and Jinchang Zhu and Haozhe Zhang and Zihao Gong and Guillaume Freychet and Mikhail Zhernenkov and Baoxing Xu and Li-Heng Cai},
  booktitle = {Chemistry of Materials},
  title     = {Three-Dimensional Printable, Extremely Soft, Stretchable, and Reversible Elastomers from Molecular Architecture-Directed Assembly},
  year      = {2021},
  publisher = {},
  volume    = {},
  number    = {},
  pages     = {},
  doi       = {},
  url       = {https://pubs.acs.org/doi/full/10.1021/acs.chemmater.0c04659},
  html      = {https://pubs.acs.org/doi/full/10.1021/acs.chemmater.0c04659},
  selected  = {false},
  project   = {/projects/7_project/},
  abstract  = {3D printing elastomers enables the fabrication of many technologically important structures and devices such as tissue scaffolds, sensors, actuators, and soft robots. However, conventional 3D printable elastomers are intrinsically stiff; moreover, the process of printing often requires external mechanical support and/or post-treatment. Here, we exploit the self-assembly of a responsive linear-bottlebrush-linear triblock copolymer to create stimuli-reversible, extremely soft, and stretchable elastomers and demonstrate their applicability as inks for in situ direct-write printing 3D structures without the aid of external mechanical support or post-treatment. By developing a procedure for controlled synthesis of such architecturally designed block copolymers, we create elastomers with extensibility up to 600% and Young’s moduli down to ∼102 Pa, 106 times softer than plastics and more than 102 times softer than all existing 3D printable elastomers. Moreover, the elastomers are thermostable and remain to be solid up to 180 °C, yet they are 100% solvent-reprocessable. Their extreme softness, stretchability, thermostability, and solvent-reprocessability bode well for future applications.},
}


@article{kyunghun2021nc,
  abbr      = {Nat. Commun.},
  preview   = {contact_lens.png},
  author    = {Kyunghun Kim* and Ho-Joong Kim* and Haozhe Zhang* and Woohyun Park and Dawn Meyer and Min Ku Kim and Bongjoong Kim and Heun Park and Baoxing Xu and Pete Kollbaum and Bryan W Boudouris and Chi Hwan Lee},
  booktitle = {Nature Communications},
  title     = {All-printed stretchable corneal sensor on soft contact lenses for noninvasive and painless ocular electrodiagnosis},
  year      = {2021},
  publisher = {},
  volume    = {},
  number    = {},
  pages     = {},
  doi       = {},
  url       = {https://www.nature.com/articles/s41467-021-21916-8},
  html      = {https://www.nature.com/articles/s41467-021-21916-8},
  selected  = {false},
  project   = {/projects/4_project/},
  abstract  = {Electroretinogram examinations serve as routine clinical procedures in ophthalmology for the diagnosis and management of many ocular diseases. However, the rigid form factor of current corneal sensors produces a mismatch with the soft, curvilinear, and exceptionally sensitive human cornea, which typically requires the use of topical anesthesia and a speculum for pain management and safety. Here we report a design of an all-printed stretchable corneal sensor built on commercially-available disposable soft contact lenses that can intimately and non-invasively interface with the corneal surface of human eyes. The corneal sensor is integrated with soft contact lenses via an electrochemical anchoring mechanism in a seamless manner that ensures its mechanical and chemical reliability. Thus, the resulting device enables the high-fidelity recording of full-field electroretinogram signals in human eyes without the need of topical anesthesia or a speculum. The device, superior to clinical standards in terms of signal quality and comfortability, is expected to address unmet clinical needs in the field of ocular electrodiagnosis.}
}


@article{haozhe2020ijss,
  abbr      = {IJSS},
  preview   = {metasurface.png},
  author    = {Haozhe Zhang and Weizhu Yang and Baoxing Xu},
  booktitle = {International Journal of Solids and Structures},
  title     = {Rotation mechanics of optical scatters in stretchable metasurfaces},
  year      = {2020},
  publisher = {},
  volume    = {},
  number    = {},
  pages     = {},
  doi       = {},
  url       = {https://www.sciencedirect.com/science/article/pii/S0020768319305220},
  html      = {https://www.sciencedirect.com/science/article/pii/S0020768319305220},
  selected  = {false},
  project   = {/projects/5_project/},
  abstract  = {Stretchable metasurface comprised of an array of optical hard-material scatters on the surface of a soft substrate is emerging as an artificially designed structure to manipulate optical wave propagation through a mechanical means. Upon stretching the soft substrate, along with the increase of the spacing distance between hard scatters, the orientations of the hard scatters will vary due to their strong mechanical mismatch with the soft substrate, but the underlying mechanics mechanism is lacking. In the present study, we establish a theoretical mechanics framework to address the rotation of hard scatters bonded on the surface of a soft substrate subjected to a mechanical stretching load. In this model, we introduce a pseudo-interface between the hard scatters and the soft substrate and decouple the effect of in-plane stretching deformation and out-of-plane deformation in the thickness direction of the soft substrate on the basis of moment equilibrium. Besides, the shear stress field along the thickness direction of three-dimensional soft substrate is formulated from that of a two-dimensional plane model by introducing a thickness factor. The effect of spacing distance, geometric shape, and initial orientation of hard scatters and thickness of the soft substrate on the scatter rotation is elucidated. Extensive finite element analyses (FEA) are performed and the results show good agreement with the theoretical predictions in both scatter rotation and stress distribution. We further construct a stretchable metasurface and demonstrate that the refraction of incident lights can be tuned by controlling the rotation of scatters. The mechanics theory established here provides a foundation to design mechanically controllable metasurfaces by leveraging the rotation of hard-material scatters.},
  }
